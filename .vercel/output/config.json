{
	"version": 3,
	"routes": [
		{
			"src": "/blog",
			"dest": "/blog/"
		},
		{
			"src": "/blog/",
			"status": 308,
			"headers": {
				"Location": "/blog"
			}
		},
		{
			"src": "/projects",
			"dest": "/projects/"
		},
		{
			"src": "/projects/",
			"status": 308,
			"headers": {
				"Location": "/projects"
			}
		},
		{
			"src": "/blog/from-overthinking-nextjs-to-shipping-with-sveltekit",
			"dest": "/blog/from-overthinking-nextjs-to-shipping-with-sveltekit/"
		},
		{
			"src": "/blog/from-overthinking-nextjs-to-shipping-with-sveltekit/",
			"status": 308,
			"headers": {
				"Location": "/blog/from-overthinking-nextjs-to-shipping-with-sveltekit"
			}
		},
		{
			"src": "/blog/stepping-back-to-build-a-stronger-foundation",
			"dest": "/blog/stepping-back-to-build-a-stronger-foundation/"
		},
		{
			"src": "/blog/stepping-back-to-build-a-stronger-foundation/",
			"status": 308,
			"headers": {
				"Location": "/blog/stepping-back-to-build-a-stronger-foundation"
			}
		},
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "/.*",
			"dest": "/![-]/catchall"
		}
	],
	"overrides": {
		"index.html": {
			"path": ""
		},
		"blog.html": {
			"path": "blog"
		},
		"projects.html": {
			"path": "projects"
		},
		"blog/from-overthinking-nextjs-to-shipping-with-sveltekit.html": {
			"path": "blog/from-overthinking-nextjs-to-shipping-with-sveltekit"
		},
		"blog/stepping-back-to-build-a-stronger-foundation.html": {
			"path": "blog/stepping-back-to-build-a-stronger-foundation"
		}
	}
}